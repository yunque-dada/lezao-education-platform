# 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# 端口（Railway 会自动设置）
PORT=3000

# JWT 密钥（请修改为安全的随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this

# 数据库连接（Railway 会自动配置）
# 格式: postgres://username:password@host:port/database
DATABASE_URL=postgres://your-username:your-password@your-host:5432/your-database

# 节点环境
NODE_ENV=production
