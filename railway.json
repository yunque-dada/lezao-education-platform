{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "installCommand": "npm install --legacy-peer-deps"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node server.js",
    "healthcheck": {
      "path": "/api/health",
      "port": 8080,
      "interval": 30,
      "timeout": 10
    }
  }
}
